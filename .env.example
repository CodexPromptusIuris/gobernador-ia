# ============================================
# Gobernador IA - Environment Template
# ============================================
# Copy this file to .env and set your values

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=gobernador_ia
DATABASE_URL=postgresql://postgres:change-this-password@db:5432/gobernador_ia

# Backend Configuration
PORT=8080
JWT_SECRET=change-this-secret-key-min-32-chars
ADMIN_PASSWORD=ChangeMe@123
WEBHOOK_API_KEY=change-this-webhook-key

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info
